# Environment
.env
.env.*
!.env.example
!.env.docker.example

# Dependencies
/api/vendor/
/frontend/node_modules/

# Build output
/frontend/dist/
/frontend/.angular/
/build/
/dist/
/coverage/

# Laravel runtime files
/api/storage/*.key
/api/storage/logs/*
/api/storage/framework/cache/*
/api/storage/framework/sessions/*
/api/storage/framework/testing/*
/api/storage/framework/views/*
/api/bootstrap/cache/*
!/api/storage/logs/.gitignore
!/api/storage/framework/cache/.gitignore
!/api/storage/framework/sessions/.gitignore
!/api/storage/framework/testing/.gitignore
!/api/storage/framework/views/.gitignore
!/api/bootstrap/cache/.gitignore

# Public generated files
/api/public/hot
/api/public/storage
/api/public/mix-manifest.json

# Secrets and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Logs and temp files
*.log
*.tmp
*.temp
*.pid
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# .NET build artifacts
/api-dotnet/.vs/
/api-dotnet/**/bin/
/api-dotnet/**/obj/
*.user

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
*.old
*.orig

# Docker override
docker-compose.override.yml
