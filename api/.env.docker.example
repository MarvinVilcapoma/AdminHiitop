# Copiar a .env cuando uses Docker Compose (api + hiitop-db)
# cp .env.docker.example .env  (y luego php artisan key:generate dentro del contenedor)

APP_NAME=Hiitop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8050

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=hiitop-db
DB_PORT=3306
DB_DATABASE=hiitop
DB_USERNAME=hiitop
DB_PASSWORD=hiitop_secret

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
