{
  "Application": {
    "Name": "AdminHiitopV2",
    "TimeZone": "America/Lima",
    "Culture": "es-PE",
    "Currency": "PEN"
  },

  "ConnectionStrings": {
    "SqlServerConnection": "Server=localhost;Database=AdminHiitopV2;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True",
    "MySqlConnection": "Server=127.0.0.1;Port=3306;Database=hiitop;User=root;Password=;SslMode=None;AllowPublicKeyRetrieval=True;"
  },

  "Database": {
    "Provider": "MySql",
    "AutoMigrate": true,
    "AutoSeed": true,
    "CommandTimeoutSeconds": 60,
    "EnableSensitiveDataLogging": false
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },

  "Session": {
    "TokenExpirationDays": 1
  },

  "ElectronicBilling": {
    "Provider": "NubeFact",
    "NubeFact": {
        "Environment": "Demo",
        "ApiUrl": "https://api.nubefact.com/api/v1/8fd9e413-8fe4-43a9-b80b-e4acad635ae9",
        "DemoApiUrl": "https://demo.nubefact.com/api/v1/03989d1a-6c8c-4b71-b1cd-7d37001deaa0",
        "ProductionApiUrl": "",
        "ApiToken": "",
        "OperationMode": "beta",
        "TimeoutSeconds": 30,
        "RetryAttempts": 3,
        "RetryDelaySeconds": 5
    },
    "DocumentDefaults": {
      "DefaultInvoiceSeries": "F001",
      "DefaultReceiptSeries": "B001",
      "DefaultCreditNoteSeries": "FC01",
      "DefaultDebitNoteSeries": "FD01",
      "IgvPercentage": 18,
      "SendAutomatically": false
    }
  },

  "Pos": {
    "MaxPosWarehouses": 3,
    "AllowNegativeStock": false,
    "AllowSaleWithoutCustomer": true,
    "PricesIncludeIgv": true,
    "AllowDraftSales": true,
    "MaxItemsPerSale": 200
  },

  "Pagination": {
    "DefaultPageSize": 20,
    "MaxPageSize": 100
  },

  "Swagger": {
    "Enabled": true,
    "Title": "AdminHiitopV2 API",
    "Version": "v1"
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },

  "Shopify": {
    "ShopDomain":      "hiitop-3136.myshopify.com",
    "ClientId":        "856f73ecd60d6b560ae5c1a54c828d51",
    "ClientSecret": "",
    "AccessToken":     "",
    "ApiVersion":      "2026-04",
    "TimeoutSeconds":  30,
    "SyncInventory":      true,
    "UseShopifyStock":    true,
    "DefaultLocationId":  0,
    "UseShopifyMode":     true
  },

  "AllowedHosts": "*"
}
